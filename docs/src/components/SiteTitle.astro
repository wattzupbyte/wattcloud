---
// Replaces Starlight's default SiteTitle.
// Cloud motif (DESIGN.md §29.1) + "Wattcloud" wordmark, identical placement
// to the SPA drawer header so the docs read as the same product.
const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
  <svg
    viewBox="0 0 48 48"
    width="28"
    height="28"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M30 7.5 a16.5 16.5 0 0 0 -14.76 9.13 A12 12 0 1 0 13.5 40.5 H30 a16.5 16.5 0 0 0 0 -33 Z"
      stroke="hsl(142,60%,45%)"
      stroke-width="2.5"
      fill="hsl(142, 40%, 18%)"
      fill-opacity="0.45"
      stroke-linejoin="round"
    />
  </svg>
  <span>{siteTitle}</span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--sl-color-text);
    text-decoration: none;
  }
</style>
