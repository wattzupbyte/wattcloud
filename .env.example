# Wattcloud — environment template.
# Copy to .env and fill in the values before running. Never commit a filled .env.
#
# BYO-only stack: the relay server forwards ciphertext between your SPA and your
# chosen storage providers. No managed database, no auth, no SMTP.

# =============================================================================
# BYO RELAY SERVER
# =============================================================================

# Public domain that serves the SPA and relay endpoints (behind TLS).
BYO_DOMAIN=example.com

# JWT signing key for relay session cookies. Min 32 bytes.
# Generate: openssl rand -base64 48
RELAY_SIGNING_KEY=

# HMAC key for share owner-tokens. MUST differ from RELAY_SIGNING_KEY
# (domain-separation: JWT signing vs raw-HMAC primitives never share a key).
# Generate: openssl rand -base64 48
RELAY_SHARE_SIGNING_KEY=

# HMAC key for hashing device UUIDs in the stats database.
# The raw UUID is never stored; only HMAC-SHA256(key, uuid) is persisted.
# Generate: openssl rand -hex 32
BYO_STATS_HMAC_KEY=

# =============================================================================
# OAuth client IDs — obtain from each provider's developer console.
# These are PUBLIC values (PKCE is the security boundary). All five are
# served to the SPA at runtime via /config.json (see Phase 4.5) — the deploy
# script writes this file from the .env at provision time.
# =============================================================================

# Google Cloud Console → OAuth 2.0 Client ID, scope: drive.file
BYO_GDRIVE_CLIENT_ID=

# https://www.dropbox.com/developers, scope: files.content.read+write
BYO_DROPBOX_CLIENT_ID=

# Azure Portal → App registrations, scope: Files.ReadWrite
BYO_ONEDRIVE_CLIENT_ID=

# https://app.box.com/developers/console, scope: root_readwrite
BYO_BOX_CLIENT_ID=

# https://docs.pcloud.com/my_apps/, permissions: manage files
BYO_PCLOUD_CLIENT_ID=

# Base URL the SPA uses as its own origin (redirect URIs, relay WebSocket).
BYO_BASE_URL=https://example.com

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Set to 'production' for production deployments.
ENVIRONMENT=development
