# Wattcloud — environment template.
#
# This file ships inside the release tarball. deploy-vps.sh copies it to
# /etc/wattcloud/wattcloud.env (0600 root) on first install and fills in
# secrets automatically. Operators then run `wattcloud oauth-setup` to
# populate the optional BYO_*_CLIENT_ID values at their own pace.
#
# BYO-only stack: the relay server forwards ciphertext between your SPA
# and your chosen storage providers. No managed database, no auth, no
# SMTP. All plaintext stays on the client.

# =============================================================================
# RELAY SERVER (filled by deploy-vps.sh)
# =============================================================================

# Public domain that serves the SPA and relay endpoints (behind TLS).
BYO_DOMAIN=

# Base URL the SPA uses as its own origin (redirect URIs, relay WebSocket).
BYO_BASE_URL=

# JWT signing key for relay session cookies. Min 32 bytes.
# deploy-vps.sh generates this via `openssl rand -base64 48`.
RELAY_SIGNING_KEY=

# HMAC key for share owner-tokens. MUST differ from RELAY_SIGNING_KEY
# (SPEC-BYO SC1: domain separation — JWT signing vs raw-HMAC primitives
# never share key material).
RELAY_SHARE_SIGNING_KEY=

# HMAC key for hashing device UUIDs in the stats database.
# The raw UUID is never stored; only HMAC-SHA256(key, uuid) is persisted.
STATS_HMAC_KEY=

# Comma-separated IPs the relay trusts for X-Forwarded-For / X-Real-IP.
# Caddy runs on the same host and fronts TLS, so the default trusts
# loopback only. Expand if you put a load balancer in front.
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Environment marker consumed by byo-relay.
ENVIRONMENT=production

# Enrollment gate posture — whether strangers who find this URL can use the
# relay. Valid values: `open` (default on upgrades, preserves existing
# behaviour) or `restricted` (default on fresh installs — requires an
# owner-issued invite code before any operational request). Unset or
# unrecognised values fall back to `open`. See README §Access Control.
WATTCLOUD_ENROLLMENT_MODE=

# =============================================================================
# ABUSE / RATE-LIMIT PROTECTIONS
#
# All optional with sensible defaults. Override only if you have a
# reason — every value is a tradeoff between hardening and friction
# for legitimate clients. SECURITY.md §14 "Abuse Protections (Relay)"
# documents the threat model and what each knob actually buys you.
#
# Per-IP limits use the IPv4 /32 or IPv6 /64 of the client (X-Forwarded-For
# is consulted only when the TCP peer is in TRUSTED_PROXY_IPS).
# =============================================================================

# ── Authentication & enrollment ─────────────────────────────────────────────

# PoW difficulty (leading zero bits) for /relay/auth/challenge solutions.
# Higher = more compute per cookie. 18 ≈ 0.5–1 s on mobile. Range 1..=32.
POW_DIFFICULTY_BITS=18

# Per-IP cap on /relay/auth/challenge requests per minute.
AUTH_CHALLENGE_PER_MIN=10

# Per-IP cap on /relay/info requests per minute (the unauthenticated boot
# probe). Public endpoint, cheap, but rate-limited so it isn't a free
# firehose.
ENROLLMENT_INFO_PER_MIN=60

# JWT relay-auth cookie lifetime (seconds). Lower = more frequent re-PoW.
RELAY_COOKIE_TTL_SECS=600

# ── Share storage abuse caps ────────────────────────────────────────────────

# Per-IP daily upload byte budget across all shares. Set 0 to disable.
# Default 50 GB.
SHARE_DAILY_BYTES_PER_IP=53687091200

# Max bytes for a single share blob. Enforced at upload start via the
# Content-Length header, so a runaway client can't drain disk mid-stream.
# Default 1 GB.
SHARE_MAX_BLOB_BYTES=1073741824

# Per-IP share creations per hour / per day.
SHARE_CREATE_PER_HOUR_PER_IP=10
SHARE_CREATE_PER_DAY_PER_IP=50

# Per-IP cap on aggregate bytes of *active* (non-revoked, non-expired)
# shares — blocks "use the relay as free durable hosting". Existing shares
# carry on; only new creates are rejected. Default 5 GB.
SHARE_TOTAL_STORAGE_PER_IP_BYTES=5368709120

# Per-share download caps (recipient side). Defaults: 10 GETs/h, 1 GB/h.
SHARE_DOWNLOAD_PER_HOUR_PER_SHARE=10
SHARE_DOWNLOAD_BYTES_PER_HOUR_PER_SHARE=1073741824

# Max concurrent in-flight downloads per share_id. Anti-amplification
# brake; extra recipients get 429 + retry-after.
SHARE_MAX_CONCURRENT_DOWNLOADS=1

# Slow-start: for the first SHARE_SLOW_START_SECS after a share is created,
# downloads are bandwidth-capped to SHARE_SLOW_START_MAX_BPS. Buys
# operator reaction time on a viral leak. Defaults 5 min @ 10 MB/s.
SHARE_SLOW_START_SECS=300
SHARE_SLOW_START_MAX_BPS=10485760

# Reject new share creation when SHARE_STORAGE_DIR's filesystem is at or
# above this fraction full. Range 0..=100.
DISK_WATERMARK_PERCENT=80

# ── SFTP relay abuse caps ───────────────────────────────────────────────────

# Per-IP concurrent open SFTP relay sessions.
SFTP_MAX_CONCURRENT_PER_IP=3

# SFTP authentication failures per IP per 5-minute window before a 1-hour
# block. Failures are pre-recorded and refunded on success — a parallel-
# guess attack cannot multiply its budget.
SFTP_FAILED_AUTH_PER_5MIN=5

# Comma-separated allowlist of SFTP destination hosts. Empty (default)
# allows all hosts; the SSRF guard still blocks loopback / RFC1918 / link-
# local / reserved address space regardless. Supports `host.example.com`
# and `*.example.com` (single-label wildcard).
SFTP_HOST_ALLOWLIST=

# Comma-separated allowlist of SFTP destination ports.
SFTP_ALLOWED_PORTS=22,2022,2222

# ── Stats endpoint caps ─────────────────────────────────────────────────────

# Per-device-hash batches per minute on POST /relay/stats.
STATS_INGEST_PER_MIN=10

# Max events per stats batch. The WASM ring buffer is intentionally 4×
# this so events accumulate across multiple flush windows without
# head-of-line blocking.
STATS_BATCH_MAX_EVENTS=200

# Max body bytes for POST /relay/stats.
STATS_MAX_BODY_BYTES=65536

# ── JSON request-body size caps ─────────────────────────────────────────────
# Tight ceilings on JSON-only endpoints; axum's default 2 MB is far
# larger than any realistic payload. These just stop a misbehaving client
# from tying up a parse task with garbage.

# /relay/auth (PoW solution + JWK).
AUTH_MAX_BODY_BYTES=16384

# /relay/share/bundle/init (kind + expires_in_secs).
BUNDLE_INIT_MAX_BODY_BYTES=4096

# =============================================================================
# UPGRADE TRUST ANCHOR (filled by deploy-vps.sh or install.sh --trusted-signer)
# =============================================================================

# Regex matched against the cosign certificate identity when verifying
# release tarballs. wattcloud-update reads this value. Forks override it
# to point at their own release.yml workflow.
TRUSTED_SIGNER_IDENTITY=^https://github\.com/thewattlabs/wattcloud/\.github/workflows/release\.yml@refs/tags/v[0-9]+\.[0-9]+\.[0-9]+.*$

# =============================================================================
# OAUTH CLIENT IDS — deferred. Not yet shipped.
#
# OAuth providers (Google Drive, Dropbox, OneDrive, Box, pCloud) are
# under active development and currently hidden from the SPA's provider
# picker. The variables below are kept commented out so the file shape
# matches what `wattcloud oauth-setup` will expect once the flow ships;
# uncomment the line for any provider you want to enable, then run
# `sudo wattcloud oauth-setup` to walk through the console wiring.
#
# These are PUBLIC values — PKCE is the security boundary, not secrecy.
# They're served to the SPA at runtime via /config.json.
# =============================================================================

# Google Cloud Console → OAuth 2.0 Client ID · scope: drive.file (sensitive)
#BYO_GDRIVE_CLIENT_ID=

# https://www.dropbox.com/developers/apps · scope: files.content.read + files.content.write
#BYO_DROPBOX_CLIENT_ID=

# Azure Portal → App registrations · scope: Files.ReadWrite
#BYO_ONEDRIVE_CLIENT_ID=

# https://app.box.com/developers/console · scope: root_readwrite
#BYO_BOX_CLIENT_ID=

# https://docs.pcloud.com/my_apps/ · permissions: manage files
#BYO_PCLOUD_CLIENT_ID=

# =============================================================================
# ACME / Caddy
# =============================================================================

# Email used for Let's Encrypt registration. Caddy reads this from its
# Caddyfile (deploy-vps.sh substitutes @@ACME_EMAIL@@).
ACME_EMAIL=
